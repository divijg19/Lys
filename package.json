{
  "name": "lys",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf .next out .velite",
    "clean:all": "rm -rf .next out .velite node_modules bun.lock && bun install",
    "velite": "velite build",
    "dev": "bun velite && concurrently -k -n velite,next -c cyan,magenta \"velite dev\" \"next dev\"",
    "build": "bun clean && bun velite && next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "biome lint . --write",
    "format": "biome format . --write",
    "type-check": "bun velite && tsc --noEmit --incremental",
    "test": "vitest run",
    "test:ci": "vitest run --coverage --reporter=dot",
    "test:e2e:smoke": "node scripts/e2e-smoke.mjs",
    "qa": "bun type-check && bun lint && bun format && bun test:ci",
    "storybook": "storybook build && storybook dev -p 6006",
    "test:stories": "vitest run --project storybook"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-tooltip": "1.2.9",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "next-mdx-remote": "6.0.0",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "react-icons": "5.6.0",
    "resend": "6.12.4",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "three": "0.184.0",
    "use-debounce": "10.1.1",
    "velite": "0.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@chromatic-com/storybook": "5.2.1",
    "@next/bundle-analyzer": "16.2.7",
    "@storybook/addon-a11y": "10.4.2",
    "@storybook/addon-docs": "10.4.2",
    "@storybook/addon-links": "10.4.2",
    "@storybook/addon-onboarding": "10.4.2",
    "@storybook/nextjs-vite": "10.4.2",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/browser": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "axe-core": "4.12.0",
    "concurrently": "10.0.3",
    "jsdom": "29.1.1",
    "playwright": "1.60.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-slug": "6.0.0",
    "storybook": "10.4.2",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "esbuild",
    "sharp"
  ],
  "volta": {
    "node": "22.20.0"
  }
}