{
  "name": "lys",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf .next out .velite",
    "clean:all": "rimraf .next out .velite node_modules bun.lock && bun install",
    "velite": "velite build",
    "dev": "bun velite && concurrently -k -n velite,next -c cyan,magenta \"velite dev\" \"next dev\"",
    "build": "bun clean && bun velite && next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "biome lint . --write",
    "format": "biome format . --write",
    "type-check": "bun velite && tsc --noEmit --incremental",
    "test": "vitest run",
    "test:ci": "vitest run --coverage --reporter=dot",
    "qa": "bun type-check && bun lint && bun format && bun test:ci",
    "storybook": "storybook build && storybook dev -p 6006",
    "test:stories": "vitest run --project storybook"
  },
